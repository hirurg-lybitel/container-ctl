# API key (Bearer or X-API-Key)
CONTAINER_CTL_API_KEY=CHANGE_ME

# Docker socket
CONTAINER_CTL_DOCKER_SOCKET=/var/run/docker.sock

# Allow POST .../containers/:name with action "delete" (docker rm -f)
CONTAINER_CTL_ALLOW_DELETE=false

# HTTP listen (bind inside Docker network; do not expose publicly without a firewall)
CONTAINER_CTL_LISTEN_HOST=0.0.0.0
CONTAINER_CTL_LISTEN_PORT=3080
